# ═══════════════════════════════════════════════════════════════
# PIVERSE BACKEND — Environment Variables
# Copy to .env and fill in. NEVER commit .env.
# ═══════════════════════════════════════════════════════════════

# ─── LLM (Pi's brain) ───────────────────────────────────────────
# OpenAI API key. The backend starts without this, but /chat returns
# "AI channel not configured" until a real key is set.
OPENAI_API_KEY=

# Optional. Defaults to gpt-4o.
OPENAI_MODEL=gpt-4o

# ─── Solana RPC (for /holdings token gate) ──────────────────────
# Paid RPC strongly recommended (Helius / QuickNode / Triton).
SOLANA_RPC=

# ─── Token Gate enforcement ─────────────────────────────────────
# When "true", /guess requires the wallet to hold an access token.
# Leave unset/false during testing.
REQUIRE_HOLDER=false

# ─── Autonomous feed auth ───────────────────────────────────────
# Shared secret with agent-runtime. Same value on both sides.
# Generate: openssl rand -hex 24
AGENT_KEY=

# ─── CORS ───────────────────────────────────────────────────────
# Comma-separated allowed origins for production.
CORS_ORIGIN=https://piverse.fun,https://www.piverse.fun,https://piverse-nu.vercel.app

# ═══════════════════════════════════════════════════════════════
# PRIZE PAYOUTS — REAL MONEY. Read carefully.
# ═══════════════════════════════════════════════════════════════

# Master switch. When "true", the backend will AUTOMATICALLY send
# USDC to epoch winners after each 24h epoch closes. Leave FALSE
# until the treasury is funded and you've tested on devnet.
PAYOUTS_ENABLED=false

# Treasury wallet that holds the 1,000 USDC prize pool.
# This is SEPARATE from Pi's agent wallet — do NOT reuse pi-wallet.
# Value = base58-encoded secret key of the treasury keypair.
# Generate: solana-keygen new --outfile treasury.json
#           then base58-encode the secret key.
TREASURY_PRIVKEY=

# USDC mint address.
#   Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
#   Devnet:  4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU  (test USDC)
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ─── Server ─────────────────────────────────────────────────────
PORT=3000
