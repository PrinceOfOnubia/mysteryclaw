# ═══════════════════════════════════════════════════════════════
# MYSTERYCLAW BACKEND — Environment Variables
# Copy to .env and fill in. NEVER commit .env.
# ═══════════════════════════════════════════════════════════════

# ─── LLM (Mysterio's brain) ───────────────────────────────────────────
# OpenAI API key. The backend starts without this, but /chat returns
# "AI channel not configured" until a real key is set.
OPENAI_API_KEY=

# Optional. Defaults to gpt-4o.
OPENAI_MODEL=gpt-4o

# ─── Solana RPC (for /holdings token gate) ──────────────────────
# Paid RPC strongly recommended (Helius / QuickNode / Triton).
SOLANA_RPC=
SOLANA_CLUSTER=mainnet

# ─── Postgres (Railway) ─────────────────────────────────────────
# Required for production prize state, verified wallets, winners,
# payout attempts, and autonomous posts.
DATABASE_URL=

# ─── Token Gate enforcement ─────────────────────────────────────
# When "true", /guess requires the wallet to hold an access token.
# Leave unset/false during testing.
REQUIRE_HOLDER=false

# ─── Autonomous feed auth ───────────────────────────────────────
# Shared secret with agent-runtime. Same value on both sides.
# Generate: openssl rand -hex 24
AGENT_KEY=

# ─── Admin controls ─────────────────────────────────────────────
# Required for normal /admin login. User must connect this Phantom wallet
# and sign a backend nonce to receive a short-lived admin session.
ADMIN_WALLET=

# Required for stable short-lived admin JWT sessions across restarts.
# Generate: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Emergency/manual API fallback only. Do not use this as the normal
# frontend login flow.
ADMIN_KEY=

# Optional public status values for the admin panel. Never set secrets here.
AGENT_WALLET_PUBKEY=
MYST_TOKEN_MINT=

# Optional server-side bridge for future AWS agent controls. Do not expose
# AGENT_CONTROL_KEY to the frontend.
AGENT_CONTROL_URL=
AGENT_CONTROL_KEY=

# ─── CORS ───────────────────────────────────────────────────────
# Comma-separated allowed origins for production.
CORS_ORIGIN=https://mysteryclaw.xyz,https://www.mysteryclaw.xyz,https://mysteryclaw.vercel.app

# ═══════════════════════════════════════════════════════════════
# PRIZE PAYOUTS — REAL MONEY. Read carefully.
# ═══════════════════════════════════════════════════════════════

# Master switch. When "true", the admin payout endpoint can send
# USDC to unpaid verified winners after each 24h epoch closes. Leave
# FALSE until the treasury is funded and production review is complete.
PAYOUTS_ENABLED=false

# Treasury wallet that holds the 1,000 USDC prize pool.
# This is SEPARATE from Mysterio's agent wallet — do NOT reuse the agent wallet.
# Value = base58-encoded secret key of the treasury keypair.
# Generate: solana-keygen new --outfile treasury.json
#           then base58-encode the secret key.
TREASURY_PRIVKEY=

# USDC mint address, mainnet only.
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ─── Server ─────────────────────────────────────────────────────
PORT=3000
