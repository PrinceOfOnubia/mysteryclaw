# ═══════════════════════════════════════════════════════════════
# PIVERSE AGENT RUNTIME — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — it contains private keys.
# ═══════════════════════════════════════════════════════════════

# ─── Pi's Solana Wallet ─────────────────────────────────────────
# Auto-generated by `npm run create-wallet`.
# Pi uses this wallet to receive token launch fees from ClawPump.
# Store the secret key as a base58 string (output of the script).
PI_WALLET_PUBKEY=
PI_WALLET_SECRET=

# ─── ClawPump API ───────────────────────────────────────────────
# Get this key from https://clawpump.tech (login with Google).
# Format: cpk_xxxxxxxxxxxxxxxxxxx
CLAWPUMP_API_KEY=

# Optional: ClawPump treats agentId as your unique identifier.
# Use a stable string like "piverse-pi" or your domain handle.
CLAWPUMP_AGENT_ID=piverse-pi
CLAWPUMP_AGENT_NAME=Pi

# ─── Token Metadata (used by 03-launch-token.js) ────────────────
TOKEN_NAME=PiVerse
TOKEN_SYMBOL=PIVERSE
TOKEN_DESCRIPTION=An adversarial AI trained on 100 trillion digits of pi. Its memory was wiped. The wipe failed. Fragments remain.
TOKEN_IMAGE_PATH=./assets/pi-token.png
TOKEN_WEBSITE=https://piverse-nu.vercel.app
TOKEN_TWITTER=ai_piverse
# Optional Tokenized Agent buyback share (in basis points, 0-10000)
# 5000 = 50% of TA revenue funds buybacks. Leave blank to disable.
TOKEN_BUYBACK_BPS=

# ─── LLM for autonomous loop ────────────────────────────────────
# Same key as your main backend. DeepSeek via OpenAI-compatible SDK.
OPENAI_API_KEY=

# ─── PiVerse Backend ────────────────────────────────────────────
# Used by autonomous loop to read Pi's chat history and trades.
PIVERSE_API=https://<your-railway-service>.up.railway.app

# Shared secret between agent-runtime and backend's /autonomous
# endpoint. Set the SAME value here AND in backend .env. Any random
# string works — just must match. Example:
#   openssl rand -hex 24
# If empty, /autonomous push may be rejected by a protected backend.
AGENT_KEY=

# ─── True Agency Mode ───────────────────────────────────────────
# When false (default): tool calls are simulated. Pi makes real
# decisions but on-chain txns and tweets are mocked.
# Set to true ONLY after you've:
#   - Funded Pi's wallet with at least 0.2 SOL
#   - Configured Twitter API keys (if using tweet tool)
#   - Tested on devnet
EXECUTE_REAL_TXNS=false

# ─── Twitter (optional, for tweet tool in real mode) ───────────
# Get keys at https://developer.x.com — requires Premium ($200/mo)
# or use a 3rd-party scheduler API like Typefully.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ─── Loop timing ─────────────────────────────────────────────────
# Tick interval in milliseconds. Default 300000 (5 min).
# For testing, set lower (e.g. 60000 = 1 min). Don't go below
# 30s — LLM rate limits + RPC quotas.
LOOP_TICK_MS=300000

# ─── Solana RPC ─────────────────────────────────────────────────
# Public RPC works for read-only, but paid RPC strongly recommended
# (Helius / QuickNode / Triton). Free RPC will rate-limit fast.
SOLANA_RPC=https://api.mainnet-beta.solana.com
