# ═══════════════════════════════════════════════════════════════
# MYSTERYCLAW AGENT RUNTIME — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — it contains secrets.
# ═══════════════════════════════════════════════════════════════

# ─── ClawPump API ───────────────────────────────────────────────
# Get this key from https://clawpump.tech (login with Google).
# Format: cpk_xxxxxxxxxxxxxxxxxxx
CLAWPUMP_API_KEY=

# Hosted ClawPump agent UUID from the agent dashboard.
# Example format: 12345678-abcd-1234-abcd-123456789abc
CLAWPUMP_AGENT_ID=
CLAWPUMP_AGENT_NAME=Mysterio
# Hosted ClawPump agent wallet from the dashboard. Public address only.
# Do not add a hosted wallet private key here.
CLAWPUMP_AGENT_WALLET_PUBKEY=

# ─── Token Metadata (used by 03-launch-token.js) ────────────────
TOKEN_NAME=MysteryClaw
TOKEN_SYMBOL=MYSTO
TOKEN_DESCRIPTION=MysteryClaw is an on-chain AI mystery game where holders question Mysterio, hunt hidden clues, and compete in reward epochs guarded by $MYSTO.
TOKEN_IMAGE_PATH=./assets/myst-token.png
TOKEN_IMAGE_URL=https://mysteryclaw.xyz/assets/mysteryclaw-logo.jpg
TOKEN_WEBSITE=https://mysteryclaw.xyz
TOKEN_TWITTER=https://x.com/mysteryclawpump?s=11
MYSTO_TOKEN_MINT=G6E1GoffSHQU2GGuZXcojs1RRYx6MmtgJVeB69s3eYKQ
# Optional Tokenized Agent buyback share (in basis points, 0-10000)
# 5000 = 50% of TA revenue funds buybacks. Leave blank to disable.
TOKEN_BUYBACK_BPS=

# ─── LLM for autonomous loop ────────────────────────────────────
# Same OpenAI key as your main backend.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── MysteryClaw Backend ────────────────────────────────────────
# Used by autonomous loop to read Mysterio's chat history and trades.
MYSTERYCLAW_API=https://piverse-production.up.railway.app
# Shared secret between agent-runtime and backend's /autonomous
# endpoint. Set the SAME value here AND in backend .env. Any random
# string works — just must match. Example:
#   openssl rand -hex 24
# If empty, /autonomous push may be rejected by a protected backend.
AGENT_KEY=

# ─── True Agency Mode ───────────────────────────────────────────
# When false (default): tool calls are simulated. Mysterio makes real
# decisions but on-chain txns and tweets are mocked.
# Set to true ONLY after you've:
#   - Configured Twitter API keys (if using tweet tool)
#   - Completed a mainnet launch review
EXECUTE_REAL_TXNS=false

# ─── Twitter (optional, for tweet tool in real mode) ───────────
# Get keys at https://developer.x.com — requires Premium ($200/mo)
# or use a 3rd-party scheduler API like Typefully.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ─── Loop timing ─────────────────────────────────────────────────
# Tick interval in milliseconds. Default 300000 (5 min).
# For testing, set lower (e.g. 60000 = 1 min). Don't go below
# 30s — LLM rate limits + RPC quotas.
LOOP_TICK_MS=300000

# ─── Solana RPC ─────────────────────────────────────────────────
# Public RPC works for read-only, but paid RPC strongly recommended
# (Helius / QuickNode / Triton). Free RPC will rate-limit fast.
SOLANA_RPC=https://api.mainnet-beta.solana.com
